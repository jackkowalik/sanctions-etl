{
    "name": "jackkowalik/sanctions-etl",
    "description": "Sanctions data ETL in PHP. Syncs 14 government sources into normalized JSONL or MySQL.",
    "type": "project",
    "license": "MIT",
    "keywords": ["sanctions", "ofac", "aml", "compliance", "etl"],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-simplexml": "*",
        "ext-xmlreader": "*",
        "ext-zip": "*",
        "psr/log": "^3.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "suggest": {
        "ext-pdo_mysql": "Required for the MySQL storage backend"
    },
    "autoload": {
        "psr-4": {
            "SanctionsEtl\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
