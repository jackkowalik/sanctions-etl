# Storage backend: json (default) or mysql
STORAGE=json

# json backend: where JSONL output and the manifest are written
OUTPUT_DIR=./out

# mysql backend
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sanctions
DB_USER=sanctions
DB_PASS=

# Where raw source files land during a sync
DOWNLOAD_DIR=./downloads

# Keep raw downloads after a sync instead of deleting them
KEEP_DOWNLOADS=false

# SAM.gov API key for the us_sam_exclusions source.
# Free key: sam.gov -> sign in -> Account Details -> API Key.
# Leave empty and that source is skipped with a warning.
SAM_API_KEY=
